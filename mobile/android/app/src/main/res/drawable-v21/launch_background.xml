<?xml version="1.0" encoding="utf-8"?>
<!-- Nurby splash: near-black background with the centered lens icon.
     Bitmaps live in drawable-*dpi/launch_icon.png (see mobile/tool/gen_icon.py). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/launch_background_color" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/launch_icon" />
    </item>
</layer-list>
