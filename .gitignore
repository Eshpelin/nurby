logs/

# Agent eval artifact
.eval-report.md

# Claude Code. ship the shared dev-workflow agents/skills + launch config,
# but never the local settings, runtime locks, or session state.
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/launch.json
.claude/settings.local.json
.claude/scheduled_tasks.lock

# macOS
.DS_Store

# Nested preview tooling
frontend/.claude/
.venv-test/

# ux-army harness runtime artifacts
# Runtime logs from the ux-army harness stack (api, ffmpeg feeds,
# ingestion, perception).
testing/harness/*.log
testing/harness/users.md
# Generated persona logins. Never commit: the repo is public.
testing/harness/credentials.json
# Per-run bookkeeping. Local-only: the run reports, the findings ledger,
# and the cursor are how each run resumes on THIS machine, not something
# other people need in the public repo. Must be gitignored (not merely
# untracked) so the ux-army worktree's `git clean -fd` / `reset --hard`
# preserve them across runs. Persona files and harness scripts stay
# tracked; only the mutable run outputs are ignored.
testing/runs/
testing/state.json
testing/FINDINGS.md
dev/feeds/
# Recordings/thumbnails/audio written by the ux-army harness stack.
dev/uxtest-data/
