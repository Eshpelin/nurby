# Postgres (container runs on 5433 to avoid conflict with local Postgres)
POSTGRES_PASSWORD=nurby_dev
DATABASE_URL=postgresql+asyncpg://nurby:nurby_dev@localhost:5433/nurby

# Redis
REDIS_URL=redis://localhost:6379/0

# MediaMTX
MEDIAMTX_API_URL=http://localhost:9997

# Storage
RECORDINGS_PATH=./recordings
THUMBNAILS_PATH=./thumbnails

# Frontend (set in frontend/.env.local or pass to Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_WEBRTC_URL=http://localhost:8889
