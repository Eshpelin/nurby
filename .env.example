# Nurby environment template. Copy to .env and adjust.
#
# SECURITY. for anything beyond local testing you MUST change the values
# marked CHANGE-ME below. The defaults here are for a throwaway local dev
# stack only. Do not deploy with them.

# ── Database ────────────────────────────────────────────────────────
# CHANGE-ME. set a strong, unique Postgres password before deploying.
# Compose wires this into DATABASE_URL for every service.
POSTGRES_PASSWORD=nurby_dev
DATABASE_URL=postgresql+asyncpg://nurby:nurby_dev@localhost:5433/nurby

# ── Auth ────────────────────────────────────────────────────────────
# CHANGE-ME. signing secret for login tokens. If left unset, Nurby
# generates a random one per process, which logs everyone out on every
# restart. Set a strong persistent value. generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MediaMTX (live video relay) ─────────────────────────────────────
MEDIAMTX_API_URL=http://localhost:9997

# ── Storage ─────────────────────────────────────────────────────────
RECORDINGS_PATH=./recordings
THUMBNAILS_PATH=./thumbnails

# ── Public URL (used to build clip + event links in alerts) ─────────
# Set to the address users reach Nurby at, e.g. https://nurby.example.com
PUBLIC_BASE_URL=

# ── Demo camera (optional) ──────────────────────────────────────────
# Looping sample footage offered as a one-click demo camera on first run.
NURBY_DEMO_VIDEO_URL=https://nurby.ai/static/SecurityCamCompilation.mp4

# ── Local AI (optional) ─────────────────────────────────────────────
# Override where Nurby looks for Ollama. From a Docker host this is
# usually http://host.docker.internal:11434
OLLAMA_BASE_URL=

# ── Email (optional, for email rule actions) ────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# ── CORS (optional) ─────────────────────────────────────────────────
# Comma-separated extra origins allowed to call the API.
CORS_ORIGINS=

# ── Prebuilt images (optional) ──────────────────────────────────────
# Pull released images from GHCR instead of building locally. Set the
# owner to the GitHub user/org that publishes the images and pick a
# version tag (or latest). Then. docker compose pull && docker compose up -d
NURBY_REGISTRY_OWNER=eshpelin
NURBY_VERSION=latest

# ── Frontend (local dev outside Docker only) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_WEBRTC_URL=http://localhost:8889
